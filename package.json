{
  "name": "chess-tournament-manager",
  "version": "1.0.0",
  "private": true,
  "description": "Chess Tournament Management System — SvelteKit + PostgreSQL",
  "type": "module",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:vite": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "db:init": "node scripts/db-init.js",
    "db:seed": "node scripts/db-seed.js",
    "test": "node scripts/test-pairing.mjs",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^6.0.0",
    "@sveltejs/kit": "^2.22.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "embedded-postgres": "^18.4.0-beta.17",
    "svelte": "^5.20.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "postgres": "^3.4.5"
  }
}
