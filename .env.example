# PostgreSQL connection string.
# Local example:
#   DATABASE_URL="postgres://postgres:postgres@localhost:5432/chess"
# Hosted (Neon / Supabase) example — note sslmode=require:
#   DATABASE_URL="postgres://user:pass@ep-xxx.aws.neon.tech/chess?sslmode=require"
DATABASE_URL="postgres://postgres:postgres@localhost:5432/chess"
